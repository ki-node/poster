{
  "name": "poster-forge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "^22.13.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && npm run budget",
    "build:embedded": "npm run check:clean-source && npm run typecheck && vite build --mode embedded && npm run budget:embedded",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "eslint . --max-warnings=0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:e2e": "npm run build && npm run build:embedded && playwright test",
    "test:e2e:ci": "playwright test",
    "check": "npm run format:check && npm run lint && npm run test && npm run build && npm run build:embedded && npm run test:builds",
    "budget": "node scripts/check-bundle-size.mjs",
    "budget:embedded": "node scripts/check-bundle-size.mjs dist-embedded",
    "check:clean-source": "node scripts/assert-clean-build-source.mjs",
    "test:builds": "node scripts/check-build-output.mjs",
    "test:reproducible": "node scripts/check-reproducible-build.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
